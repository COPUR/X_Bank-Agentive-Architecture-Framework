@startuml c4_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container Diagram - X_Bank Agent-Native Architecture

System_Boundary(harness_boundary, "Cognitive Orchestration Harness") {
    Container(agent_gateway, "Kong Agent Gateway & Security LLM", "Kong API Gateway / vLLM", "Manages agent fleet, routes traffic, and enforces Cognitive Security & Streaming DLP.")
    
    Container(ingestion_domain, "Ingestion Domain Agent", "Spring Boot / Hexagonal DDD", "Autonomous intent-driven agent mapping logical features to BIAN service domains.")
    Container(topology_domain, "Topology Domain Agent", "Spring Boot / Hexagonal DDD", "Autonomous intent-driven agent querying CMDB and drafting low-level design schemas.")
    Container(compliance_domain, "Compliance Domain Agent", "Spring Boot / Hexagonal DDD", "Intercepts workflows, executes pgvector compliance audits, and blocks pipelines.")
    Container(governance_domain, "Governance Domain Agent", "Spring Boot / Hexagonal DDD", "Orchestrates sign-offs, verifies OIDC RBAC, and manages Human-in-the-Loop workflows.")
    Container(quality_domain, "Quality Domain Agent", "Spring Boot / Hexagonal DDD", "Performs Semantic Triangle checks and tracks workload amplification metrics.")
    
    ContainerDb(memory_banks, "Persistent Memory Banks", "pgvector / Qdrant", "Long-Term Memory with strict write filters, trust scoring, and active regulatory vector texts.")
    Container(orchestration_domain, "Orchestration Domain (Temporal + Kafka)", "Temporal + Kafka (MSK)", "Manages real-time intent-driven workflows and stateful long-running execution.")
    
    Container(semantic_cache, "Semantic Vector Cache", "Redis / Vector Search", "Caches semantic representations of prompts to bypass heavy model inference.")
    Container(local_llm, "Stateless Compute Cascades (Mixture of Experts) (Cascades)", "vLLM / SLM + LLaMA", "Mixture of Experts: Fast SLMs for simple tasks, local LLaMA-3-70B for complex reasoning.")
}

System_Ext(atlassian, "Atlassian Suite (Jira/Confluence)", "SaaS Enterprise Planning")
System_Ext(github_ext, "GitHub VCS", "Source Repository")

Rel(atlassian, agent_gateway, "Dispatches Jira webhooks to")
Rel(agent_gateway, semantic_cache, "Checks for similar intents in")
Rel(agent_gateway, orchestration_domain, "Initiates secure workflow intent in")
Rel(ingestion_domain, confluence, "Fetches XHTML format from")
Rel(orchestration_domain, ingestion_domain, "Dispatches ingestion intent to")
Rel(ingestion_domain, orchestration_domain, "Returns extracted context to")
Rel(orchestration_domain, topology_domain, "Dispatches topology mapping intent to")
Rel(topology_domain, orchestration_domain, "Returns LLD schema to")
Rel(orchestration_domain, compliance_domain, "Dispatches compliance audit intent to")
Rel(compliance_domain, memory_banks, "Queries vector rules & stores state securely in")
Rel(compliance_domain, local_llm, "Validates logic via model cascades in")
Rel(orchestration_domain, governance_domain, "Triggers Human-in-the-loop sign-off intent via")
Rel(governance_domain, argocd, "Syncs approved metadata to")
Rel(github_ext, agent_gateway, "Triggers PR checks via")
Rel(agent_gateway, quality_domain, "Routes PR for Semantic Triangle check to")
@enduml
