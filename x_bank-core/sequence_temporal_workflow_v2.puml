@startuml sequence_temporal_workflow_v2
!theme plain
autonumber

skinparam BoxPadding 10
skinparam ParticipantPadding 10

actor "Jira / Confluence\n(Webhook)" as jira
box "Cognitive Orchestration Harness" #LightBlue
    participant "Kong Agent Gateway\n(& Security LLM)" as kong
    participant "Temporal Orchestrator\n(OpenFinanceWorkflow)" as temporal
    participant "AgentHarness\n(Managed Core)" as harness
    participant "Dynamic Tools\n(Ingest, Topo, Comp)" as tools
    participant "PersistentMemoryManager" as memory
    participant "RestLlmProvider" as llm
end box

database "pgvector / CMDB" as dbs
participant "ArgoCD\n(GitOps)" as argocd

== Ingestion & Translation ==
jira -> kong: POST /webhook/intent (PRD payload)
kong -> kong: Security LLM: Scan for Prompt Injection
kong -> temporal: Trigger OpenFinanceWorkflow(PRD)
temporal -> tools: RequirementOrchestrator: translateToTasks(PRD)
tools --> temporal: Returns List<TaskDTO> (JSON Array)

== Dynamic Ralph Workflow Execution (Iterative Loop) ==
loop For each Task in List<TaskDTO>
    temporal -> temporal: Generate Isolated SessionID
    temporal -> harness: executeTask(SessionID, AgentConfiguration, TaskDescription)
    
    harness -> memory: loadContext(SessionID)
    memory --> harness: Previous Context / Clean State
    
    loop Dynamic Sequencing (Max Iterations = 10)
        harness -> llm: invoke(SystemPrompt, Context, ToolDefinitions)
        llm --> harness: ModelResponse (Tool Call or Text)
        
        alt isToolCall == true
            harness -> harness: LifecycleHooks.beforeToolCall()
            harness -> tools: Execute Dynamic Tool (e.g. VectorSearch, JiraConnector)
            tools -> dbs: Query external DBs
            dbs --> tools: Results
            tools --> harness: Tool Execution Result
            harness -> harness: LifecycleHooks.afterToolCall() (Trace & Token Logging)
            harness -> harness: Append result to Context
        else Model Returned Text
            harness -> memory: saveContext(SessionID, Final Result)
            harness --> temporal: Task Result
            break
        end
    end
    
    alt Task requires HITL (e.g. CAB Approval)
        temporal -> temporal: Workflow.await(cabVoteReceived)
        jira -> temporal: CAB / ARB Sign-off received
        temporal -> temporal: Task marked COMPLETED
    end
end

== Quality Audit & GitOps ==
temporal -> argocd: Sync Approved Manifests
argocd --> temporal: Deployment Success
temporal --> jira: Update ticket to 'Done'

@enduml
